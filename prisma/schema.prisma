generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model News {
  id              String    @id @default(uuid())
  title           String
  slug            String?   @unique
  lead            String?
  content         String
  excerpt         String?
  imageUrl        String?
  imageCaption    String?
  imageAlt        String?
  category        String?
  tags            String?
  metaTitle       String?
  metaDescription String?
  focusKeyword    String?
  author          String?
  status          String    @default("published")
  scheduledAt     DateTime?
  embeds          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
}

model Gallery {
  id        String    @id @default(uuid())
  title     String
  imageUrl  String
  createdAt DateTime  @default(now())
  category  String?
  event     String?
  eventDate DateTime?
}

model Setting {
  key   String @id
  value String
}

model Pendaftaran {
  id            String   @id @default(uuid())
  namaLengkap   String
  tempatLahir   String
  tanggalLahir  DateTime
  jenisKelamin  String
  asalSekolah   String
  namaAyah      String
  namaIbu       String
  nomorWhatsapp String
  alamat        String
  status        String   @default("Pending")
  createdAt     DateTime @default(now())
}
