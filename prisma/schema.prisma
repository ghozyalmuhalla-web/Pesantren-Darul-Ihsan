generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model News {
  id        String   @id @default(uuid())
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model Gallery {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}
